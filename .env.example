# Copy file này thành .env và sửa giá trị thực tế. KHÔNG commit .env.

# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
# Bind interface. Mặc định 127.0.0.1 (chỉ nhận qua nginx reverse proxy).
# KHÔNG dùng 0.0.0.0 trên server public — sẽ phơi cổng trần bypass Cloudflare/nginx.
HOST=127.0.0.1

# CORS allowlist (phân tách bằng dấu phẩy). Rỗng = chỉ same-origin.
# App tự phục vụ là same-origin nên thường để rỗng; chỉ thêm khi có FE khác domain.
CORS_ALLOWED_ORIGINS=https://bugtracking.mktproxy.com

# Database (SQLite hôm nay; sau này đổi sang Postgres bằng DB_DRIVER=pg + DATABASE_URL)
DB_DRIVER=sqlite
DB_PATH=./data.db

# Legacy JSON file để migrate 1 lần khi khởi động (nếu tồn tại)
LEGACY_JSON=./data.json

# File storage
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
# Khi đổi sang S3 (giai đoạn 4):
# STORAGE_DRIVER=s3
# S3_BUCKET=bugtrack-prod
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=        # tùy chọn cho MinIO/Backblaze

# Auth (giai đoạn 1: stub, không bật. Giai đoạn 2: bật thật)
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Audit log
AUDIT_ENABLED=false

# Default workspace khi chưa có auth thật
DEFAULT_WORKSPACE=default
